EXPO_PUBLIC_INSTANT_APP_ID=your_instant_app_id
EXPO_PUBLIC_SENTRY_DSN=

# Native Google sign-in
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
EXPO_PUBLIC_INSTANT_GOOGLE_IOS_CLIENT_NAME=google
EXPO_PUBLIC_INSTANT_GOOGLE_WEB_CLIENT_NAME=google-web

# Native Apple sign-in (Instant OAuth client name)
EXPO_PUBLIC_INSTANT_APPLE_CLIENT_NAME=apple

# Production API origins for preview / release builds
EXPO_PUBLIC_REFERRAL_API_BASE_URL=https://escolife.expo.app
EXPO_PUBLIC_ACCOUNT_API_BASE_URL=https://escolife.expo.app

# Legal / support
EXPO_PUBLIC_APP_URL=https://escolife.expo.app
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://escolife.expo.app/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://escolife.expo.app/terms
EXPO_PUBLIC_SUPPORT_URL=https://escolife.expo.app/support
EXPO_PUBLIC_SUPPORT_EMAIL=booking@escobeach-danang.com

# Restaurant geofence
EXPO_PUBLIC_RESTAURANT_LATITUDE=
EXPO_PUBLIC_RESTAURANT_LONGITUDE=
EXPO_PUBLIC_RESTAURANT_RADIUS_METERS=90

# Optional app content config
EXPO_PUBLIC_ONBOARDING_VOUCHER_CODE=ES-2026
EXPO_PUBLIC_ONBOARDING_VOUCHER_SCOPE=all Club Cabanas

# Build / server secrets: store these in EAS or your deployment platform, not in tracked env files
SENTRY_AUTH_TOKEN=
INSTANT_APP_ADMIN_TOKEN=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_ID=
APPLE_SERVICES_ID=
