{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "app-release": "node scripts/app-release.js",
    "prebuild": "bunx expo prebuild --platform android",
    "prebuild:development": "bunx expo prebuild --platform android",
    "prebuild:staging": "bunx expo prebuild --platform android",
    "prebuild:production": "bunx expo prebuild --platform android",
    "type-check": "bunx tsc --noEmit",
    "install-maestro": "curl -Ls \"https://get.maestro.mobile.dev\" | bash",
    "test:ci": "node scripts/test-ci.js",
    "validate:privacy-notices": "node scripts/compliance/validate-privacy-notices.js",
    "privacy:validate": "node scripts/compliance/privacy-validate.js",
    "compliance:cannabis": "node scripts/compliance/cannabis-policy.js",
    "compliance:scan:android": "node scripts/compliance/scan-android.js",
    "data-safety:validate": "node scripts/compliance/data-safety-validate.js",
    "compliance:siwa-guard": "node scripts/compliance/siwa-guard.js",
    "compliance:lawful-bases-matrix": "node scripts/compliance/lawful-bases-matrix.js",
    "build:development:android": "eas build --platform android --profile development",
    "build:development:ios": "eas build --platform ios --profile development",
    "build:staging:android": "eas build --platform android --profile preview",
    "build:staging:ios": "eas build --platform ios --profile preview",
    "build:production:android": "eas build --platform android --profile production",
    "build:production:ios": "eas build --platform ios --profile production",
    "sentry:upload-sourcemaps": "npx sentry-expo-upload-sourcemaps dist",
    "start": "bunx expo start --tunnel",
    "start-web": "bunx expo start --web --tunnel",
    "start-web-dev": "bunx expo start --web --clear",
    "check:expo": "expo install --check",
    "doctor": "expo install --check && expo-doctor",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@instantdb/react-native": "^0.22.157",
    "@instantdb/react-native-mmkv": "^0.22.157",
    "@nkzw/create-context-hook": "^1.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.83.0",
    "@ungap/structured-clone": "^1.3.0",
    "clsx": "^2.1.1",
    "expo": "^55.0.0",
    "expo-apple-authentication": "~55.0.9",
    "expo-blur": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.14",
    "expo-web-browser": "~55.0.10",
    "i18next": "^25.8.18",
    "lucide-react-native": "^0.475.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "uniwind": "^1.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.10",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.0"
  },
  "private": true
}