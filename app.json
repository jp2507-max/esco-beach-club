{
  "expo": {
    "name": "Esco Beach Club",
    "slug": "escolife",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/42db96ce-756f-4755-97eb-e30daacff231"
    },
    "orientation": "portrait",
    "icon": "assets/images/icon.png",
    "scheme": "esco-beach-club",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "assets/app-icon.icon",
      "supportsTablet": false,
      "bundleIdentifier": "com.escobeachclub.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Esco Beach Club to access your location in the background so we can recognize when you arrive at the restaurant and unlock member-only venue offers.",
        "NSLocationWhenInUseUsageDescription": "Allow Esco Beach Club to access your location so we can show nearby events, partner perks, and venue updates.",
        "NSUserNotificationUsageDescription": "Allow Esco Beach Club to send booking updates, event reminders, and exclusive member offers.",
        "UIDesignRequiresCompatibility": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/android-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.escobeachclub.app"
    },
    "web": {
      "output": "server",
      "favicon": "assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFDF5",
          "image": "./assets/images/launch-wordmark-light.png",
          "imageWidth": 240,
          "android": {
            "imageWidth": 212,
            "resizeMode": "contain"
          },
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/launch-wordmark-dark.png"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "./plugins/with-apple-privacy-manifest",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Esco Beach Club to access your camera so you can scan bill QR codes and claim member points."
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "Allow Esco Beach Club to access your location in the background so we can recognize when you arrive at the restaurant and unlock member-only venue offers.",
          "locationWhenInUsePermission": "Allow Esco Beach Club to access your location so we can show nearby events, partner perks, and venue updates."
        }
      ],
      "expo-notifications",
      "expo-localization",
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "escolife",
          "organization": "canabro"
        }
      ],
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "42db96ce-756f-4755-97eb-e30daacff231"
      }
    },
    "owner": "jan_100"
  }
}
